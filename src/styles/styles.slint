export global StyleVars {
    in-out property <length> height-line-terminal: 24px;
    in-out property <length> size-btn-terminal: 24px;
    in-out property <color> color-line-indicator: #91EDEA;
    in-out property <length> size-line-indicator: 20px;
    in-out property <color> blur-background: #ffffff14;
    in-out property <color> blur-text: #ffffff55;
}
